{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verdure",
  "version": "0.3.0",
  "identifier": "com.local.verdure",
  "build": {
    "frontendDist": "../../quarto_viewer/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "푸르름",
        "width": 1280,
        "height": 860,
        "minWidth": 640,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
